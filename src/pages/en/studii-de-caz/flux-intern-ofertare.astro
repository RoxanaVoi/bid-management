---
import CaseStudyLayout from '../../../layouts/CaseStudyLayout.astro';
const locale = 'ro';
---
<CaseStudyLayout
  title="Clarificarea unui flux intern de ofertare pentru documentații voluminoase"
  subtitle="Am susținut echipa în structurarea responsabilităților, organizarea documentelor și reducerea blocajelor dintre funcțiile implicate."
  meta="Ofertare · Proces intern"
  label="Proces intern"
  context="Compania se confrunta cu dificultăți în gestionarea internă a procesului de ofertare, mai ales când documentațiile erau voluminoase și implicau mai multe departamente."
  challenge="Blocajele apăreau la intersecția dintre echipele comercială, tehnică și financiară, unde informațiile se pierdeau sau întârziau."
  challengeBullets={["Responsabilități neclare între departamente.", "Documente dispersate în mai multe locații.", "Termene strânse cu risc de eroare."]}
  interventionIntro="Am lucrat cu echipa pentru a clarifica fluxul de ofertare și a defini clar cine face ce și când."
  interventionSteps={["Am mapat procesul existent și am identificat blocajele.", "Am structurat responsabilitățile pe roluri.", "Am organizat documentele într-un flux mai ușor de urmărit.", "Am susținut implementarea noului mod de lucru."]}
  resultText="Echipa a obținut un proces de ofertare mai fluid, cu mai puțin risc de omisiuni și o colaborare mai eficientă."
  resultHighlights={["Responsabilități clare pe roluri", "Documente organizate coerent", "Proces mai fluid și mai rapid"]}
/>
