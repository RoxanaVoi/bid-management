---
import Layout from '../../../layouts/Layout.astro';
import CTASection from '../../../components/CTASection.astro';
import { getLocaleFromUrl, t, getLocalizedPath } from '../../../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);

const articles = locale === 'ro' ? [
  { title: 'Ghid complet PAAP 2026: Ce trebuie să știi', category: 'Ghiduri', date: '15 Mar 2026', excerpt: 'Tot ce trebuie să știi despre întocmirea și actualizarea Programului Anual al Achizițiilor Publice în 2026.' },
  { title: 'Noutăți SEAP: Modificări importante în procedura simplificată', category: 'Noutăți', date: '10 Mar 2026', excerpt: 'Platforma SEAP a introdus schimbări semnificative în modul de derulare a procedurilor simplificate.' },
  { title: 'Cum eviți cele mai frecvente greșeli la depunerea DUAE', category: 'Bune practici', date: '5 Mar 2026', excerpt: 'Ghid practic cu cele 10 greșeli frecvente la completarea DUAE și cum să le eviți.' },
  { title: 'Criterii de evaluare: calitate vs preț — ghid practic', category: 'Ghiduri', date: '28 Feb 2026', excerpt: 'Cum setezi criterii de evaluare echilibrate care atrag ofertanți de calitate fără a compromite legalitatea.' },
  { title: 'Contestații CNSC: statistici și tendințe 2025', category: 'Analize', date: '20 Feb 2026', excerpt: 'Analiză a celor mai frecvente motive de contestare și ratele de admisibilitate pe tipuri de proceduri.' },
  { title: 'Cum pregătești o ofertă câștigătoare: checklist complet', category: 'Bune practici', date: '15 Feb 2026', excerpt: 'Lista completă de verificare pentru pregătirea și depunerea unei oferte fără erori.' },
] : [
  { title: 'Complete PAAP 2026 Guide: What You Need to Know', category: 'Guides', date: '15 Mar 2026', excerpt: 'Everything you need to know about preparing and updating the Annual Public Procurement Program in 2026.' },
  { title: 'SEAP News: Important Changes in Simplified Procedure', category: 'News', date: '10 Mar 2026', excerpt: 'The SEAP platform has introduced significant changes in how simplified procedures are conducted.' },
  { title: 'How to Avoid the Most Common ESPD Submission Mistakes', category: 'Best Practices', date: '5 Mar 2026', excerpt: 'Practical guide with the 10 most common ESPD mistakes and how to avoid them.' },
  { title: 'Evaluation Criteria: Quality vs Price — Practical Guide', category: 'Guides', date: '28 Feb 2026', excerpt: 'How to set balanced evaluation criteria that attract quality bidders without compromising legality.' },
  { title: 'CNSC Complaints: 2025 Statistics and Trends', category: 'Analysis', date: '20 Feb 2026', excerpt: 'Analysis of the most common complaint reasons and admissibility rates by procedure type.' },
  { title: 'How to Prepare a Winning Bid: Complete Checklist', category: 'Best Practices', date: '15 Feb 2026', excerpt: 'Complete verification checklist for preparing and submitting an error-free bid.' },
];
---

<Layout title={t(locale, 'resources.title')}>
  <section class="bg-gradient-to-br from-navy via-navy-800 to-navy text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl sm:text-5xl font-heading font-bold mb-4">{t(locale, 'resources.title')}</h1>
      <p class="text-xl text-gray-300">
        {locale === 'ro' ? 'Articole, ghiduri și noutăți din domeniul achizițiilor publice.' : 'Articles, guides and news from the public procurement field.'}
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {articles.map((article, i) => (
          <a href={i === 0 ? getLocalizedPath(locale, '/resurse/ghid-paap-2026') : i === 5 ? getLocalizedPath(locale, '/resurse/checklist-oferta-castigatoare') : '#'} data-animate data-animate-delay={String((i % 4) + 1)} class="bg-white rounded-2xl border border-gray-100 p-6 hover:shadow-lg transition-all hover:-translate-y-1 block no-underline">
            <div class="flex items-center gap-2 mb-4">
              <span class="px-2.5 py-1 bg-accent/10 text-accent text-xs font-medium rounded-full">{article.category}</span>
              <span class="text-text-light text-xs">{article.date}</span>
            </div>
            <h3 class="text-lg font-heading font-bold text-navy mb-3 hover:text-accent transition-colors">
              {article.title}
            </h3>
            <p class="text-text-light text-sm leading-relaxed">{article.excerpt}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</Layout>
