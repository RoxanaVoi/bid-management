---
import Layout from '../../layouts/Layout.astro';
import DocumentAnalysis from '../../components/react/DocumentAnalysis';
import { getLocaleFromUrl } from '../../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const isRo = locale === 'ro';
---

<Layout title={isRo ? 'Analiză rapidă fișă de date' : 'Quick data sheet analysis'} description="Automated SEAP data sheet analysis. Upload the PDF and instantly receive: authority, object, requirements, criteria, estimated value.">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-navy via-navy-800 to-navy text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-accent/10 border border-accent/20 rounded-full mb-6">
          <div class="w-2 h-2 bg-accent rounded-full animate-pulse"></div>
          <span class="text-accent text-sm font-medium">AI-Powered</span>
        </div>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold mb-4">
          {isRo ? 'Analiză rapidă a fișei de date' : 'Quick data sheet analysis'}
        </h1>
        <p class="text-lg text-gray-300 leading-relaxed mb-4">
          {isRo
            ? 'Încarcă fișa de date descărcată din SEAP și primești automat un sumar structurat: autoritate, tip procedură, obiect, cerințe, criterii de punctaj, valoare estimată.'
            : 'Upload the data sheet downloaded from SEAP and automatically receive a structured summary: authority, procedure type, object, requirements, scoring criteria, estimated value.'}
        </p>
        <p class="text-sm text-gray-400 bg-white/5 border border-white/10 rounded-lg px-4 py-3">
          <svg class="w-4 h-4 inline mr-1.5 text-warning" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          {isRo
            ? 'Aceasta este o analiză automată orientativă. Nu constituie opinie juridică sau consultanță profesională.'
            : 'This is an automated indicative analysis. It does not constitute legal opinion or professional advice.'}
        </p>
      </div>
    </div>
  </section>

  <!-- Analysis Tool -->
  <section class="py-16 bg-white">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <DocumentAnalysis client:load locale={locale} />
    </div>
  </section>
</Layout>
