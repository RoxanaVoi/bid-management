---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/react/ContactForm';
import { getLocaleFromUrl, t } from '../../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
---

<Layout title={t(locale, 'contactPage.title')} description="Contactează Equalys pentru consultanță achiziții publice sau solicită demo ePaap. office@bid-management.ro | +40 746 188 797">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-navy via-navy-800 to-navy text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl sm:text-5xl font-heading font-bold mb-4">{t(locale, 'contactPage.title')}</h1>
      <p class="text-xl text-gray-300">
        {locale === 'ro'
          ? 'Contactează-ne pentru consultanță sau solicită un demo al platformei ePaap.'
          : 'Contact us for consulting or request a demo of the ePaap platform.'}
      </p>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-12">
        <!-- Form -->
        <div class="lg:col-span-2">
          <ContactForm client:load locale={locale} />
        </div>

        <!-- Contact info -->
        <div class="space-y-8">
          <div class="bg-surface rounded-2xl p-6 border border-gray-100">
            <h3 class="font-heading font-bold text-navy mb-4">
              {locale === 'ro' ? 'Informații contact' : 'Contact Information'}
            </h3>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                <div>
                  <p class="text-sm text-text-light">Email</p>
                  <a href="mailto:office@bid-management.ro" class="text-navy font-medium hover:text-accent transition-colors">office@bid-management.ro</a>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                <div>
                  <p class="text-sm text-text-light">{locale === 'ro' ? 'Telefon' : 'Phone'}</p>
                  <a href="tel:+40746188797" class="text-navy font-medium hover:text-accent transition-colors">+40 746 188 797</a>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <div>
                  <p class="text-sm text-text-light">{locale === 'ro' ? 'Adresă' : 'Address'}</p>
                  <p class="text-navy font-medium">București, România</p>
                </div>
              </li>
            </ul>
          </div>

          <div class="bg-gradient-to-br from-accent to-accent-dark rounded-2xl p-6 text-white">
            <h3 class="font-heading font-bold mb-3">
              {locale === 'ro' ? 'Analiză gratuită' : 'Free Analysis'}
            </h3>
            <p class="text-white/80 text-sm leading-relaxed mb-4">
              {locale === 'ro'
                ? 'Încarcă documentația ta și primești un rezumat rapid cu zone de atenție, powered by AI.'
                : 'Upload your documentation and receive a quick summary with attention areas, powered by AI.'}
            </p>
            <a href={locale === 'ro' ? '/ro/analizeaza-documentatia' : '/en/analizeaza-documentatia'} class="inline-flex items-center gap-2 text-white font-semibold text-sm hover:gap-3 transition-all">
              {locale === 'ro' ? 'Încearcă acum' : 'Try now'}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
