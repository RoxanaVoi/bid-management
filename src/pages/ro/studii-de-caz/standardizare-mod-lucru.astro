---
import CaseStudyLayout from '../../../layouts/CaseStudyLayout.astro';
const locale = 'ro';
---
<CaseStudyLayout
  title="Standardizarea unui mod de lucru pentru analiză și ofertare"
  subtitle="Am definit o abordare repetabilă pentru documentații recurente, astfel încât echipa să lucreze mai rapid, mai coerent și mai previzibil."
  meta="Proceduri interne · Eficiență"
  label="Standardizare"
  context="Compania participa frecvent la proceduri similare, dar fiecare ofertă era abordată diferit, fără un cadru comun de lucru."
  challenge="Lipsa unui proces standardizat genera inconsistențe, consum excesiv de timp și dificultăți în integrarea membrilor noi în echipă."
  challengeBullets={["Abordare diferită de la ofertă la ofertă.", "Dificultăți în transferul de cunoștințe.", "Timp pierdut cu organizarea ad-hoc."]}
  interventionIntro="Am construit un cadru de lucru standardizat, adaptat tipurilor de proceduri frecvent întâlnite."
  interventionSteps={["Am analizat procedurile recurente și am identificat pașii comuni.", "Am definit template-uri și checklisturi pentru etapele critice.", "Am stabilit reguli clare de organizare a documentelor.", "Am documentat procesul pentru integrarea ușoară a membrilor noi."]}
  resultText="Echipa a obținut un mod de lucru repeatabili, mai rapid și mai consistent, reducând semnificativ efortul de organizare pentru fiecare ofertă."
  resultHighlights={["Proces standardizat și repetabil", "Integrare mai rapidă a membrilor noi", "Reducere semnificativă a timpului de organizare"]}
/>
