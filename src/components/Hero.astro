---
import { getLocaleFromUrl, t, getLocalizedPath } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
---

<section class="relative overflow-hidden bg-gradient-to-br from-navy via-navy-800 to-navy min-h-[85vh] flex items-center">
  <!-- Animated background elements -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute -top-40 -right-40 w-80 h-80 bg-accent/10 rounded-full blur-3xl animate-float"></div>
    <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-accent/5 rounded-full blur-3xl animate-float" style="animation-delay: 3s;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-accent/5 rounded-full blur-3xl"></div>
    <!-- Grid pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Content -->
      <div>
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-accent/10 border border-accent/20 rounded-full mb-8">
          <div class="w-2 h-2 bg-accent rounded-full animate-pulse"></div>
          <span class="text-accent text-sm font-medium">Powered by AI</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-bold text-white leading-tight mb-6">
          {t(locale, 'hero.title')}
        </h1>

        <p class="text-lg text-gray-300 leading-relaxed mb-10 max-w-xl">
          {t(locale, 'hero.subtitle')}
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={getLocalizedPath(locale, '/analizeaza-documentatia')}
            class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-accent hover:bg-accent-dark text-white font-semibold rounded-xl transition-all hover:shadow-lg hover:shadow-accent/25 hover:-translate-y-0.5"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            {t(locale, 'hero.ctaPrimary')}
          </a>
          <a
            href="#role-selector"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/20 text-white font-semibold rounded-xl hover:bg-white/10 transition-all"
          >
            {t(locale, 'hero.ctaSecondary')}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
          </a>
        </div>
      </div>

      <!-- Right: Mockup illustration -->
      <div class="hidden lg:block relative">
        <div class="relative">
          <!-- Main app mockup -->
          <div class="glass-dark rounded-2xl p-6 shadow-2xl">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-3 h-3 rounded-full bg-danger/70"></div>
              <div class="w-3 h-3 rounded-full bg-warning/70"></div>
              <div class="w-3 h-3 rounded-full bg-success/70"></div>
              <span class="text-gray-500 text-xs ml-2">ePaap — Platformă Achiziții</span>
            </div>
            <div class="space-y-3">
              <div class="bg-white/5 rounded-lg p-3">
                <div class="text-accent text-xs font-medium mb-1">PAAP 2026</div>
                <div class="flex gap-2">
                  <div class="h-2 bg-accent/60 rounded-full flex-[3]"></div>
                  <div class="h-2 bg-accent/30 rounded-full flex-[2]"></div>
                  <div class="h-2 bg-accent/10 rounded-full flex-1"></div>
                </div>
              </div>
              <div class="bg-white/5 rounded-lg p-3">
                <div class="text-success text-xs font-medium mb-1">Referate aprobate</div>
                <div class="text-white text-2xl font-heading font-bold">147</div>
              </div>
              <div class="grid grid-cols-2 gap-2">
                <div class="bg-white/5 rounded-lg p-3">
                  <div class="text-gray-400 text-xs mb-1">CPV Grupate</div>
                  <div class="text-white text-lg font-bold">23</div>
                </div>
                <div class="bg-white/5 rounded-lg p-3">
                  <div class="text-gray-400 text-xs mb-1">Proceduri</div>
                  <div class="text-white text-lg font-bold">12</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Floating card -->
          <div class="absolute -right-8 -bottom-8 glass rounded-xl p-4 shadow-xl animate-float" style="animation-delay: 1s;">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-success/20 rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div>
                <div class="text-navy text-sm font-semibold">AI Analysis</div>
                <div class="text-text-light text-xs">Document verified</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
