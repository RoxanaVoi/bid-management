---
import { getLocaleFromUrl, t, getLocalizedPath } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const isRo = locale === 'ro';
---

<section class="relative overflow-hidden bg-gradient-to-br from-navy via-navy-800 to-navy min-h-0 flex items-center">
  <!-- Subtle texture background -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute -top-40 -right-40 w-80 h-80 bg-accent/8 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-accent/5 rounded-full blur-3xl"></div>
    <div class="absolute inset-0 opacity-[0.02]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; viewBox=&quot;0 0 40 40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot; fill-rule=&quot;evenodd&quot;%3E%3Cpath d=&quot;M0 40L40 0H20L0 20M40 40V20L20 40&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 lg:py-16">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <!-- Left: Content -->
      <div>
        <h1 class="text-3xl sm:text-4xl lg:text-[2.75rem] xl:text-5xl font-heading font-bold text-white leading-[1.15] mb-5">
          {isRo
            ? 'Infrastructura invizibilă a achizițiilor publice bine făcute.'
            : 'The invisible infrastructure behind well-executed public procurement.'}
        </h1>

        <p class="text-base lg:text-lg text-gray-300 leading-relaxed mb-8 max-w-xl">
          {isRo
            ? 'Pentru autorități contractante și operatori economici care au nevoie de procese solide, documente mai clare și instrumente digitale construite pentru lumea reală.'
            : 'For contracting authorities and economic operators who need solid processes, clearer documents, and digital tools built for the real world.'}
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={getLocalizedPath(locale, '/analizeaza-documentatia')}
            class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-accent hover:bg-accent-dark text-white font-semibold rounded-xl transition-all hover:shadow-lg hover:shadow-accent/25 hover:-translate-y-0.5"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            {t(locale, 'hero.ctaPrimary')}
          </a>
          <a
            href="#role-selector"
            class="inline-flex items-center justify-center gap-2 px-7 py-3.5 border border-white/20 text-white font-semibold rounded-xl hover:bg-white/10 transition-all"
          >
            {t(locale, 'hero.ctaSecondary')}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
          </a>
        </div>
      </div>

      <!-- Right: Product Ecosystem Visual -->
      <div class="hidden lg:block relative">
        <!-- Main dashboard mockup -->
        <div class="relative bg-white/[0.04] border border-white/[0.08] rounded-2xl p-5 backdrop-blur-sm">
          <!-- Dashboard header -->
          <div class="flex items-center justify-between mb-5">
            <div class="flex items-center gap-2.5">
              <div class="w-7 h-7 bg-accent/20 rounded-lg flex items-center justify-center">
                <span class="text-accent font-bold text-xs">e</span>
              </div>
              <span class="text-white/70 text-xs font-medium tracking-wide">ePaap · Ecosystem</span>
            </div>
            <div class="flex gap-1.5">
              <div class="w-2 h-2 rounded-full bg-success/60"></div>
              <div class="w-2 h-2 rounded-full bg-warning/60"></div>
              <div class="w-2 h-2 rounded-full bg-white/20"></div>
            </div>
          </div>

          <!-- 4 Widget grid -->
          <div class="grid grid-cols-2 gap-3 mb-4">
            <!-- Widget 1: PAAP Planificare -->
            <div class="bg-white/[0.06] border border-white/[0.06] rounded-xl p-3.5">
              <div class="flex items-center gap-2 mb-2.5">
                <div class="w-5 h-5 bg-accent/15 rounded flex items-center justify-center">
                  <svg class="w-3 h-3 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                </div>
                <span class="text-white/50 text-[10px] uppercase tracking-wider">{isRo ? 'Planificare' : 'Planning'}</span>
              </div>
              <div class="text-white text-lg font-bold font-heading leading-none mb-1">PAAP 2026</div>
              <div class="flex gap-1.5 mt-2">
                <div class="h-1.5 bg-accent/50 rounded-full flex-[3]"></div>
                <div class="h-1.5 bg-accent/25 rounded-full flex-[2]"></div>
                <div class="h-1.5 bg-white/10 rounded-full flex-1"></div>
              </div>
              <div class="flex justify-between mt-2">
                <span class="text-white/30 text-[9px]">234 {isRo ? 'nevoi' : 'needs'}</span>
                <span class="text-accent text-[9px] font-medium">78%</span>
              </div>
            </div>

            <!-- Widget 2: Analiză documente -->
            <div class="bg-white/[0.06] border border-white/[0.06] rounded-xl p-3.5">
              <div class="flex items-center gap-2 mb-2.5">
                <div class="w-5 h-5 bg-success/15 rounded flex items-center justify-center">
                  <svg class="w-3 h-3 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <span class="text-white/50 text-[10px] uppercase tracking-wider">{isRo ? 'Analiză' : 'Analysis'}</span>
              </div>
              <div class="text-white text-sm font-semibold leading-snug mb-1.5">{isRo ? '12 criterii cheie extrase' : '12 key criteria extracted'}</div>
              <div class="flex gap-1 flex-wrap">
                <span class="px-1.5 py-0.5 bg-success/10 text-success text-[9px] rounded">{isRo ? 'Conform' : 'Compliant'}</span>
                <span class="px-1.5 py-0.5 bg-warning/10 text-warning text-[9px] rounded">3 {isRo ? 'atenționări' : 'warnings'}</span>
              </div>
            </div>

            <!-- Widget 3: Loturi -->
            <div class="bg-white/[0.06] border border-white/[0.06] rounded-xl p-3.5">
              <div class="flex items-center gap-2 mb-2.5">
                <div class="w-5 h-5 bg-accent/15 rounded flex items-center justify-center">
                  <svg class="w-3 h-3 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                </div>
                <span class="text-white/50 text-[10px] uppercase tracking-wider">{isRo ? 'Grupare' : 'Grouping'}</span>
              </div>
              <div class="text-white text-sm font-semibold leading-snug mb-1.5">{isRo ? '4 loturi identificate' : '4 lots identified'}</div>
              <div class="flex gap-1.5">
                {['L1', 'L2', 'L3', 'L4'].map((lot) => (
                  <div class="w-7 h-7 bg-white/[0.08] rounded text-white/60 text-[10px] font-medium flex items-center justify-center">{lot}</div>
                ))}
              </div>
            </div>

            <!-- Widget 4: Semnături & flux -->
            <div class="bg-white/[0.06] border border-white/[0.06] rounded-xl p-3.5">
              <div class="flex items-center gap-2 mb-2.5">
                <div class="w-5 h-5 bg-success/15 rounded flex items-center justify-center">
                  <svg class="w-3 h-3 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                </div>
                <span class="text-white/50 text-[10px] uppercase tracking-wider">{isRo ? 'Conformitate' : 'Compliance'}</span>
              </div>
              <div class="text-white text-sm font-semibold leading-snug mb-1.5">{isRo ? 'Soluții conforme' : 'Compliant solutions'}</div>
              <div class="flex items-center gap-1.5">
                <div class="flex -space-x-1">
                  <div class="w-5 h-5 rounded-full bg-accent/30 border border-white/10"></div>
                  <div class="w-5 h-5 rounded-full bg-success/30 border border-white/10"></div>
                  <div class="w-5 h-5 rounded-full bg-warning/30 border border-white/10"></div>
                </div>
                <span class="text-white/40 text-[9px]">3/3 {isRo ? 'aprobări' : 'approvals'}</span>
              </div>
            </div>
          </div>

          <!-- Bottom badges bar -->
          <div class="flex gap-2 flex-wrap">
            <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-white/[0.05] border border-white/[0.06] rounded-lg text-[10px] text-white/50">
              <svg class="w-3 h-3 text-accent/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
              CPV 45.21
            </span>
            <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-white/[0.05] border border-white/[0.06] rounded-lg text-[10px] text-white/50">
              <svg class="w-3 h-3 text-accent/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              2.45M RON
            </span>
            <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-white/[0.05] border border-white/[0.06] rounded-lg text-[10px] text-white/50">
              <svg class="w-3 h-3 text-accent/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              15 apr
            </span>
            <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-white/[0.05] border border-white/[0.06] rounded-lg text-[10px] text-white/50">
              <svg class="w-3 h-3 text-success/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              {isRo ? '3 semnături' : '3 signatures'}
            </span>
          </div>
        </div>

        <!-- Floating card: PAAP -->
        <div class="absolute -left-6 top-8 bg-white rounded-xl p-3 shadow-lg border border-gray-100 max-w-[180px]">
          <div class="flex items-center gap-2 mb-1.5">
            <div class="w-5 h-5 bg-accent/10 rounded flex items-center justify-center">
              <svg class="w-3 h-3 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            </div>
            <span class="text-navy text-[11px] font-semibold">{isRo ? 'PAAP generat' : 'PAAP generated'}</span>
          </div>
          <p class="text-text-light text-[10px] leading-snug">{isRo ? 'din colectare de nevoi' : 'from needs collection'}</p>
        </div>

        <!-- Floating card: Compliant -->
        <div class="absolute -right-4 bottom-16 bg-white rounded-xl p-3 shadow-lg border border-gray-100 max-w-[170px]">
          <div class="flex items-center gap-2">
            <div class="w-6 h-6 bg-success/10 rounded-full flex items-center justify-center">
              <svg class="w-3.5 h-3.5 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </div>
            <div>
              <div class="text-navy text-[11px] font-semibold">{isRo ? 'Soluții conforme' : 'Compliant solutions'}</div>
              <div class="text-text-light text-[9px]">{isRo ? 'Verificat automat' : 'Auto-verified'}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
