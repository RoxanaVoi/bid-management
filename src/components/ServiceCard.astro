---
interface Props {
  title: string;
  description: string;
  icon: string;
  delay?: string;
}

const { title, description, icon, delay = '0' } = Astro.props;
---

<div data-animate data-animate-delay={delay} class="group bg-white rounded-2xl p-6 border border-gray-100 hover:shadow-lg hover:border-accent/20 transition-all duration-300 hover:-translate-y-1">
  <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center mb-4 group-hover:bg-accent/20 transition-colors">
    <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon} />
    </svg>
  </div>
  <h3 class="text-lg font-heading font-bold text-navy mb-2">{title}</h3>
  <p class="text-text-light text-sm leading-relaxed">{description}</p>
</div>
