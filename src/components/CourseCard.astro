---
interface Props {
  title: string;
  format: string;
  duration: string;
  level: string;
  cta: string;
  delay?: string;
}

const { title, format, duration, level, cta, delay = '0' } = Astro.props;
---

<div data-animate data-animate-delay={delay} class="bg-white rounded-2xl p-6 border border-gray-100 hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
  <h3 class="text-lg font-heading font-bold text-navy mb-4">{title}</h3>

  <div class="flex flex-wrap gap-2 mb-4">
    <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-accent/10 text-accent text-xs font-medium rounded-full">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
      {format}
    </span>
    <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-navy/5 text-navy text-xs font-medium rounded-full">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      {duration}
    </span>
    <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-success/10 text-success text-xs font-medium rounded-full">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      {level}
    </span>
  </div>

  <a href="#contact" class="inline-flex items-center gap-2 text-accent text-sm font-semibold hover:gap-3 transition-all">
    {cta}
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
  </a>
</div>
