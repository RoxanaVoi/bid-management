---
import { getLocaleFromUrl, getNavItems, getAlternateLocale, getLocalizedPath } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const altLocale = getAlternateLocale(locale);
const navItems = getNavItems(locale);
const currentPath = Astro.url.pathname.replace(`/${locale}`, '') || '/';
const altHref = getLocalizedPath(altLocale, currentPath);
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-18">
      <!-- Logo -->
      <a href={getLocalizedPath(locale, '/')} class="flex items-center shrink-0">
        <img src="/images/logo-equalys.svg" alt="Equalys" class="h-10 w-auto" />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden xl:flex items-center gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2 text-sm font-medium rounded-lg transition-colors',
              Astro.url.pathname === item.href || Astro.url.pathname.startsWith(item.href + '/')
                ? 'text-accent bg-accent/10'
                : 'text-navy-light hover:text-accent hover:bg-accent/5',
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Right side -->
      <div class="flex items-center gap-3">
        <!-- Language switcher -->
        <a
          href={altHref}
          class="px-3 py-1.5 text-sm font-medium border border-navy/10 rounded-lg hover:bg-accent/5 hover:border-accent/30 transition-colors"
        >
          {altLocale.toUpperCase()}
        </a>

        <!-- Mobile menu toggle -->
        <button
          id="menu-toggle"
          class="xl:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors"
          aria-label="Toggle menu"
        >
          <svg id="menu-icon" class="w-6 h-6 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="close-icon" class="w-6 h-6 text-navy hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="xl:hidden hidden border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 py-4 space-y-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'block px-4 py-3 text-sm font-medium rounded-lg transition-colors',
            Astro.url.pathname === item.href
              ? 'text-accent bg-accent/10'
              : 'text-navy-light hover:text-accent hover:bg-accent/5',
          ]}
        >
          {item.label}
        </a>
      ))}
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-18"></div>

<script>
  const header = document.getElementById('site-header')!;
  const menuToggle = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const menuIcon = document.getElementById('menu-icon')!;
  const closeIcon = document.getElementById('close-icon')!;

  // Scroll effect
  let lastScroll = 0;
  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;
    if (currentScroll > 50) {
      header.classList.add('bg-white/90', 'backdrop-blur-md', 'shadow-sm');
    } else {
      header.classList.remove('bg-white/90', 'backdrop-blur-md', 'shadow-sm');
    }
    lastScroll = currentScroll;
  });

  // Mobile toggle
  menuToggle.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.contains('hidden');
    mobileMenu.classList.toggle('hidden');
    menuIcon.classList.toggle('hidden');
    closeIcon.classList.toggle('hidden');
    if (!isOpen) {
      header.classList.add('bg-white/90', 'backdrop-blur-md');
    }
  });
</script>
