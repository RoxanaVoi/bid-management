---
import { getLocaleFromUrl, t, getLocalizedPath } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);

const caseStudies = [
  {
    title: locale === 'ro' ? 'Procedură lucrări reabilitare clădire' : 'Building rehabilitation works procedure',
    client: locale === 'ro' ? 'Autoritate — UAT municipiu' : 'Authority — Municipal UAT',
    desc: locale === 'ro' ? 'Documentație de atribuire pentru lucrări complexe, cu caiet de sarcini tehnic detaliat și criterii de evaluare mixte.' : 'Award documentation for complex works, with detailed technical specifications and mixed evaluation criteria.',
    result: locale === 'ro' ? 'Contestații respinse, 5 ofertanți calificați' : 'Complaints rejected, 5 qualified bidders',
    tag: locale === 'ro' ? 'Lucrări' : 'Works',
  },
  {
    title: locale === 'ro' ? 'Achiziție echipamente medicale' : 'Medical equipment procurement',
    client: locale === 'ro' ? 'Autoritate — Spital regional' : 'Authority — Regional hospital',
    desc: locale === 'ro' ? 'Procedură cu loturi pentru echipamente de diagnostic și laborator, inclusiv specificații tehnice și criterii cost-calitate.' : 'Lots procedure for diagnostic and laboratory equipment, including technical specifications and quality-cost criteria.',
    result: locale === 'ro' ? 'Economie de 12% față de estimare, fără contestații' : '12% savings vs estimate, no complaints',
    tag: locale === 'ro' ? 'Furnizare' : 'Supply',
  },
  {
    title: locale === 'ro' ? 'Pregătire ofertă servicii IT' : 'IT services bid preparation',
    client: locale === 'ro' ? 'Companie — Integrator IT' : 'Company — IT Integrator',
    desc: locale === 'ro' ? 'Suport complet pentru pregătirea ofertei tehnice și financiare într-o procedură de dialog competitiv.' : 'Complete support for technical and financial bid in a competitive dialogue procedure.',
    result: locale === 'ro' ? 'Ofertă câștigătoare, punctaj maxim tehnic' : 'Winning bid, maximum technical score',
    tag: locale === 'ro' ? 'Servicii' : 'Services',
  },
];
---

<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-animate>
      <h2 class="text-3xl sm:text-4xl font-heading font-bold text-navy">
        {t(locale, 'caseStudies.title')}
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8 mb-12">
      {caseStudies.map((cs, i) => (
        <div data-animate data-animate-delay={String(i + 1)} class="group bg-white rounded-2xl border border-gray-100 overflow-hidden hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
          <div class="p-6">
            <div class="flex items-center gap-2 mb-4">
              <span class="px-3 py-1 bg-accent/10 text-accent text-xs font-medium rounded-full">
                {cs.tag}
              </span>
              <span class="text-text-light text-xs">{cs.client}</span>
            </div>

            <h3 class="text-lg font-heading font-bold text-navy mb-3 group-hover:text-accent transition-colors">
              {cs.title}
            </h3>

            <p class="text-text-light text-sm leading-relaxed mb-4">
              {cs.desc}
            </p>

            <div class="flex items-center gap-2 pt-4 border-t border-gray-100">
              <svg class="w-5 h-5 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span class="text-sm font-medium text-success">{cs.result}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center" data-animate>
      <a
        href={getLocalizedPath(locale, '/studii-de-caz')}
        class="inline-flex items-center gap-2 px-6 py-3 border-2 border-navy text-navy font-semibold rounded-xl hover:bg-navy hover:text-white transition-all"
      >
        {t(locale, 'caseStudies.viewAll')}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>
