---
import { getLocaleFromUrl, t, getLocalizedPath } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const isRo = locale === 'ro';

const caseStudies = [
  {
    slug: 'planificare-paap-autoritate',
    title: isRo ? 'Planificarea necesarului și structurarea PAAP' : 'Needs planning and PAAP structuring',
    label: isRo ? 'Autoritate' : 'Authority',
    desc: isRo ? 'Am sprijinit organizarea procesului de colectare a nevoilor și transformarea acestuia într-un flux mai clar de planificare și documentare internă.' : 'We supported the needs collection process and its transformation into a clearer planning and internal documentation flow.',
    meta: isRo ? 'Planificare & PAAP' : 'Planning & PAAP',
  },
  {
    slug: 'analiza-documentatie-loturi',
    title: isRo ? 'Analiză documentație — loturi multiple, cerințe tehnice sensibile' : 'Documentation analysis — multiple lots, sensitive technical requirements',
    label: isRo ? 'Operator economic' : 'Economic operator',
    desc: isRo ? 'Am extras cerințele relevante, am separat informațiile pe loturi și am evidențiat punctele cu impact major asupra pregătirii ofertei.' : 'We extracted relevant requirements, separated information by lots, and highlighted points with major impact on bid preparation.',
    meta: isRo ? 'Analiză documentație' : 'Documentation analysis',
  },
  {
    slug: 'training-echipa-ofertare',
    title: isRo ? 'Pregătirea unei echipe pentru participare la achiziții publice' : 'Preparing a team for public procurement participation',
    label: 'Training',
    desc: isRo ? 'Am construit un program aplicat pentru citirea documentațiilor, pregătirea DUAE și coordonarea internă a etapelor de ofertare.' : 'We built an applied program for reading documentation, ESPD preparation, and internal bidding stage coordination.',
    meta: isRo ? 'Training · Proceduri interne' : 'Training · Internal procedures',
  },
];
---

<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-animate>
      <h2 class="text-3xl sm:text-4xl font-heading font-bold text-navy">
        {t(locale, 'caseStudies.title')}
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8 mb-12">
      {caseStudies.map((cs, i) => (
        <a href={getLocalizedPath(locale, `/studii-de-caz/${cs.slug}`)} data-animate data-animate-delay={String(i + 1)} class="group bg-white rounded-2xl border border-gray-100 overflow-hidden hover:shadow-lg transition-all duration-300 hover:-translate-y-1 block no-underline">
          <div class="p-6">
            <div class="flex items-center gap-2 mb-4">
              <span class="px-3 py-1 bg-accent/10 text-accent text-xs font-medium rounded-full">
                {cs.label}
              </span>
              <span class="text-text-light text-xs">{cs.meta}</span>
            </div>

            <h3 class="text-lg font-heading font-bold text-navy mb-3 group-hover:text-accent transition-colors">
              {cs.title}
            </h3>

            <p class="text-text-light text-sm leading-relaxed mb-4">
              {cs.desc}
            </p>

            <div class="flex items-center gap-2 pt-4 border-t border-gray-100">
              <span class="inline-flex items-center gap-1 text-accent text-sm font-semibold group-hover:gap-2 transition-all">
                {isRo ? 'Vezi studiul de caz' : 'View case study'}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="text-center" data-animate>
      <a
        href={getLocalizedPath(locale, '/studii-de-caz')}
        class="inline-flex items-center gap-2 px-6 py-3 border-2 border-navy text-navy font-semibold rounded-xl hover:bg-navy hover:text-white transition-all"
      >
        {t(locale, 'caseStudies.viewAll')}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>
