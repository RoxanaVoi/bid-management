---
import { getLocaleFromUrl, t } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);

const metrics = [
  { key: 'metric1', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4' },
  { key: 'metric2', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
  { key: 'metric3', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z' },
  { key: 'metric4', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
];
---

<section class="py-24 bg-surface">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-animate>
      <h2 class="text-3xl sm:text-4xl font-heading font-bold text-navy">
        {t(locale, 'results.title')}
      </h2>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      {metrics.map((metric, i) => (
        <div data-animate data-animate-delay={String(i + 1)} class="bg-white rounded-2xl p-6 text-center shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={metric.icon} />
            </svg>
          </div>
          <div class="text-3xl sm:text-4xl font-heading font-bold text-navy mb-1" data-counter>
            {t(locale, `results.${metric.key}.value`)}
          </div>
          <div class="text-text-light text-sm">
            {t(locale, `results.${metric.key}.label`)}
          </div>
        </div>
      ))}
    </div>

    <!-- Client types band -->
    <div data-animate class="text-center">
      <p class="text-text-light text-sm font-medium tracking-wider uppercase">
        {t(locale, 'results.clients')}
      </p>
    </div>
  </div>
</section>
