---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import { getLocaleFromUrl, getLocalizedPath, getAlternateLocale } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Consultanță specializată în achiziții publice pentru autorități și companii. ePaap — platformă digitală pentru PAAP și referate.', ogImage } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const altLocale = getAlternateLocale(locale);
const currentPath = Astro.url.pathname.replace(`/${locale}`, '') || '/';
const altPath = getLocalizedPath(altLocale, currentPath);
const fullTitle = `${title} | Bid Management`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Bing Webmaster verification -->
    <meta name="msvalidate.01" content="4AD1BB1A80D67D2327750D174DB2CF51" />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:locale" content={locale === 'ro' ? 'ro_RO' : 'en_US'} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <!-- Alternate languages -->
    <link rel="alternate" hreflang="ro" href={`https://bid-management.ro${getLocalizedPath('ro', currentPath)}`} />
    <link rel="alternate" hreflang="en" href={`https://bid-management.ro${getLocalizedPath('en', currentPath)}`} />
    <link rel="canonical" href={Astro.url.href} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Equalys Services",
        "alternateName": "Bid Management",
        "url": "https://bid-management.ro",
        "logo": "https://bid-management.ro/images/logo-equalys.svg",
        "description": "Consultanță specializată în achiziții publice pentru autorități contractante și operatori economici.",
        "email": "office@bid-management.ro",
        "telephone": "+40746188797",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "București",
          "addressCountry": "RO"
        },
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+40746188797",
          "email": "office@bid-management.ro",
          "contactType": "customer service",
          "availableLanguage": ["Romanian", "English"]
        },
        "sameAs": ["https://linkedin.com/company/equalys-services"]
      },
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Bid Management",
        "url": "https://bid-management.ro",
        "inLanguage": ["ro", "en"],
        "description": "Consultanță achiziții publice, ePaap, eBid — instrumente digitale pentru planificare, analiză și ofertare."
      }
    ])} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <CookieConsent />

  </body>
</html>
