---
import Layout from './Layout.astro';
import { getLocaleFromUrl, getLocalizedPath } from '../i18n/utils';

interface Props {
  title: string;
  subtitle: string;
  meta: string;
  label: string;
  context: string;
  challenge: string;
  challengeBullets?: string[];
  interventionIntro: string;
  interventionSteps: string[];
  resultText: string;
  resultHighlights: string[];
}

const { title, subtitle, meta, label, context, challenge, challengeBullets, interventionIntro, interventionSteps, resultText, resultHighlights } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const isRo = locale === 'ro';
---

<Layout title={title}>
  <!-- Breadcrumb + Hero -->
  <section class="bg-gradient-to-br from-navy via-navy-800 to-navy text-white py-14 lg:py-18">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 mb-6">
        <a href={getLocalizedPath(locale, '/')} class="hover:text-accent transition-colors">{isRo ? 'Acasă' : 'Home'}</a>
        <span class="mx-2">/</span>
        <a href={getLocalizedPath(locale, '/studii-de-caz')} class="hover:text-accent transition-colors">{isRo ? 'Studii de caz' : 'Case Studies'}</a>
        <span class="mx-2">/</span>
        <span class="text-gray-400">{title}</span>
      </nav>

      <span class="text-accent text-sm font-medium uppercase tracking-wider">{isRo ? 'Studiu de caz' : 'Case Study'}</span>
      <h1 class="text-3xl sm:text-4xl font-heading font-bold mt-3 mb-4 leading-tight">{title}</h1>
      <p class="text-lg text-gray-300 leading-relaxed mb-6">{subtitle}</p>

      <div class="flex flex-wrap gap-2 mb-8">
        <span class="px-3 py-1 bg-accent/10 text-accent text-xs font-medium rounded-full">{label}</span>
        {meta.split(' · ').map((m) => (
          <span class="px-3 py-1 bg-white/5 text-gray-400 text-xs font-medium rounded-full">{m}</span>
        ))}
      </div>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href={getLocalizedPath(locale, '/contact')} class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-accent hover:bg-accent-dark text-white font-semibold rounded-xl transition-all">
          {isRo ? 'Discută o situație similară' : 'Discuss a similar situation'}
        </a>
        <a href={getLocalizedPath(locale, '/studii-de-caz')} class="inline-flex items-center justify-center gap-2 px-6 py-3 border border-white/20 text-white font-semibold rounded-xl hover:bg-white/10 transition-all">
          {isRo ? 'Vezi toate studiile de caz' : 'See all case studies'}
        </a>
      </div>
    </div>
  </section>

  <!-- Content -->
  <article class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 space-y-16">
      <!-- Context -->
      <section>
        <h2 class="text-2xl font-heading font-bold text-navy mb-4">Context</h2>
        <p class="text-text leading-relaxed text-lg">{context}</p>
      </section>

      <!-- Provocare -->
      <section>
        <h2 class="text-2xl font-heading font-bold text-navy mb-4">{isRo ? 'Provocare' : 'Challenge'}</h2>
        <p class="text-text leading-relaxed text-lg mb-4">{challenge}</p>
        {challengeBullets && challengeBullets.length > 0 && (
          <ul class="space-y-2">
            {challengeBullets.map((b) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-warning shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                <span class="text-text">{b}</span>
              </li>
            ))}
          </ul>
        )}
      </section>

      <!-- Intervenție -->
      <section>
        <h2 class="text-2xl font-heading font-bold text-navy mb-4">{isRo ? 'Cum am intervenit' : 'How we intervened'}</h2>
        <p class="text-text leading-relaxed text-lg mb-4">{interventionIntro}</p>
        <ul class="space-y-3">
          {interventionSteps.map((s) => (
            <li class="flex items-start gap-3">
              <div class="w-6 h-6 bg-accent/10 rounded-full flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-text leading-relaxed">{s}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- Rezultat -->
      <section>
        <h2 class="text-2xl font-heading font-bold text-navy mb-4">{isRo ? 'Rezultat' : 'Result'}</h2>
        <p class="text-text leading-relaxed text-lg mb-6">{resultText}</p>
        <div class="grid sm:grid-cols-3 gap-4">
          {resultHighlights.map((h) => (
            <div class="bg-surface rounded-xl p-4 border border-gray-100 text-center">
              <svg class="w-6 h-6 text-success mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <p class="text-sm font-medium text-navy">{h}</p>
            </div>
          ))}
        </div>
      </section>
    </div>
  </article>

  <!-- CTA final -->
  <section class="py-16 bg-gradient-to-br from-navy via-navy-800 to-navy text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-heading font-bold mb-4">{isRo ? 'Ai o situație similară?' : 'Have a similar situation?'}</h2>
      <p class="text-gray-300 text-lg mb-8 max-w-2xl mx-auto">{isRo ? 'Putem analiza contextul și propune un mod de lucru potrivit.' : 'We can analyze the context and propose a suitable work method.'}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={getLocalizedPath(locale, '/analizeaza-documentatia')} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-accent hover:bg-accent-dark text-white font-semibold rounded-xl transition-all">
          {isRo ? 'Trimite documentația' : 'Submit documentation'}
        </a>
        <a href={getLocalizedPath(locale, '/contact')} class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/20 text-white font-semibold rounded-xl hover:bg-white/10 transition-all">
          {isRo ? 'Discută cu noi' : 'Talk to us'}
        </a>
      </div>
    </div>
  </section>
</Layout>
